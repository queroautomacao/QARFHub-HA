{
  "domain": "qarfhub",
  "name": "QA RF Hub",
  "codeowners": ["@queroautomacao"],
  "config_flow": true,
  "dependencies": [],
  "documentation": "https://github.com/queroautomacao/QARFHub-HA",
  "homekit": {},
  "integration_type": "hub",
  "iot_class": "local_push",
  "issue_tracker": "https://github.com/queroautomacao/QARFHub-HA/issues",
  "requirements": ["websocket-client==1.8.0", "aiofiles"],
  "ssdp": [
    {
      "deviceType": "urn:schemas-rstrouse-org:device:ESPSomfyRTS:1"
    },
    {
      "deviceType": "urn:schemas-qarfhub-org:device:QARFHub:1"
    }
  ],
  "version": "2.5.0",
  "zeroconf": [
    {
      "type": "_espsomfy_rts._tcp.local.",
      "properties": { "model": "espsomfy*" }
    },
    {
      "type": "_qarfhub._tcp.local.",
      "properties": { "model": "qarfhub*" }
    }
  ]
